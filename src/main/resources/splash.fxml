<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.geometry.Insets?>

<!-- Rounded Rectangle Splash Screen Configuration -->
<StackPane fx:id="rootPane" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" 
           prefHeight="360.0" prefWidth="540.0" 
           style="-fx-background-color: linear-gradient(from 0% 0% to 100% 100%, #39FF14, #D500F9, #007BFF); -fx-background-radius: 40; -fx-padding: 4;" 
           xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <!-- Inner Container with Background Animation (StackPane to allow layering) -->
      <StackPane fx:id="innerContainer" style="-fx-background-color: linear-gradient(to bottom right, #0F2027, #203A43, #2C5364); -fx-background-radius: 36;">
         <children>
            <!-- NEW: Particle Canvas for "Salpicadores" -->
            <javafx.scene.canvas.Canvas fx:id="particleCanvas" width="530" height="350" />
            
            <!-- LAYER 1: Background Decoration (Sewing Theme) - NOW VISIBLE -->
            <javafx.scene.layout.Pane opacity="0.25">
               <children>
                  <!-- STITCHING BORDER EFFECT -->
                  <javafx.scene.shape.Rectangle width="530" height="350" arcWidth="40" arcHeight="40" fill="TRANSPARENT" 
                                                stroke="WHITE" strokeWidth="2" strokeType="INSIDE" 
                                                style="-fx-stroke-dash-array: 8 12; -fx-opacity: 0.4;" layoutX="5" layoutY="5"/>
                  
                  <!-- BUTTONS (Stylized) -->
                  <javafx.scene.shape.Circle centerY="45" centerX="45" radius="20" fill="TRANSPARENT" stroke="WHITE" strokeWidth="2" opacity="0.5"/>
                  <javafx.scene.shape.Circle centerY="45" centerX="45" radius="3" fill="WHITE" opacity="0.8"/>
                  
                  <javafx.scene.shape.Circle centerY="310" centerX="490" radius="25" fill="TRANSPARENT" stroke="WHITE" strokeWidth="2" opacity="0.5"/>
                  <javafx.scene.shape.Circle centerY="306" centerX="486" radius="2" fill="WHITE" opacity="0.8"/>
                  <javafx.scene.shape.Circle centerY="314" centerX="494" radius="2" fill="WHITE" opacity="0.8"/>

                  <!-- THREAD LINES (Floating Curves) -->
                  <javafx.scene.shape.QuadCurve startX="0" startY="150" controlX="250" controlY="40" endX="540" endY="200" 
                                              fill="TRANSPARENT" stroke="WHITE" strokeWidth="1" opacity="0.15" />
                  <javafx.scene.shape.QuadCurve startX="540" startY="300" controlX="250" controlY="340" endX="0" endY="260" 
                                              fill="TRANSPARENT" stroke="WHITE" strokeWidth="1" opacity="0.15" />
               </children>
            </javafx.scene.layout.Pane>

            <!-- LAYER 2: Content (Centered) -->
            <VBox alignment="CENTER" spacing="8.0">
               <padding>
                  <Insets top="20" bottom="20" left="30" right="30"/>
               </padding>
               <children>
                  <!-- Large Hero Icon -->
                  <ImageView fx:id="logoImage" fitHeight="110.0" fitWidth="110.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@vectors/logo_small.png" />
                     </image>
                     <effect>
                        <DropShadow color="rgba(0,0,0,0.6)" radius="30" spread="0.25" />
                     </effect>
                  </ImageView>
                  
                  <!-- Brand Name Text -->
                  <Label text="PALANT" 
                         style="-fx-text-fill: white; -fx-font-family: 'Segoe UI Black'; -fx-font-size: 38; -fx-letter-spacing: 4; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.4), 10, 0, 0, 0);" />
                  
                  <!-- Horizontal Layout: Title + Version -->
                  <HBox alignment="CENTER" spacing="8">
                      <Label text="SISTEMA DE PEDIDOS" 
                             style="-fx-text-fill: #cfd8dc; -fx-font-family: 'Segoe UI Semibold'; -fx-font-size: 14; -fx-letter-spacing: 2;" />
                      
                      <Label text="|" 
                             style="-fx-text-fill: #78909c; -fx-font-size: 14;" />

                      <!-- Version Number -->
                      <Label text="v2.8" 
                             style="-fx-text-fill: #00E676; -fx-font-family: 'Consolas'; -fx-font-size: 14; -fx-font-weight: bold;" />
                  </HBox>

                  <VBox alignment="CENTER" spacing="8" maxWidth="400">
                     <padding>
                        <Insets top="20" />
                     </padding>
                     <!-- Progress Bar (High Presence - Solid & Framed) -->
                     <ProgressBar fx:id="progressBar" prefWidth="380.0" prefHeight="12.0" progress="0.0" 
                                  style="-fx-accent: #00E676; -fx-control-inner-background: #0d161c; -fx-background-radius: 6; -fx-border-color: rgba(255,255,255,0.15); -fx-border-radius: 6; -fx-border-width: 1; -fx-padding: 0;" />
                                  
                     <Label fx:id="lblStatus" text="Iniciando motor grǭfico..." 
                            style="-fx-text-fill: #90a4ae; -fx-font-family: 'Segoe UI'; -fx-font-size: 11; -fx-font-weight: bold;" />
                  </VBox>
                  
                  <!-- Copyright Footer -->
                  <Label text="© 2026 PALANT | DESIGNED BY KENNY CASO" 
                         style="-fx-text-fill: #607d8b; -fx-font-size: 10; -fx-font-weight: bold;" translateY="8" />
               </children>
            </VBox>
         </children>
      </StackPane>
   </children>
 </StackPane>
